# Cloudflare Pages / Netlify-style headers.
# If the Lovable hosting layer ignores this file it is a harmless no-op.
#
# Long cache for hashed build assets — filenames change on every Vite build,
# so it is safe to cache them effectively forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Hashed font files emitted by Vite live under /assets/ and are covered above.
# Static images that are NOT content-hashed (favicons, OG images) get a
# moderate cache so updates still propagate within a day.
/favicon.ico
  Cache-Control: public, max-age=86400
/favicon-32.png
  Cache-Control: public, max-age=86400
/favicon-96.png
  Cache-Control: public, max-age=86400
/favicon-192.png
  Cache-Control: public, max-age=86400
/favicon-512.png
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400
/og-image.png
  Cache-Control: public, max-age=86400
/og-image-dark.png
  Cache-Control: public, max-age=86400
/og-pricing.png
  Cache-Control: public, max-age=86400
/og-help.png
  Cache-Control: public, max-age=86400
/safari-pinned-tab.svg
  Cache-Control: public, max-age=86400
/placeholder.svg
  Cache-Control: public, max-age=86400

# index.html and route-level files MUST NOT be cached at the edge —
# they reference content-hashed asset URLs that change on every deploy.
/
  Cache-Control: no-cache, must-revalidate, max-age=0
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/site.webmanifest
  Cache-Control: public, max-age=86400

# Apply security headers to every HTML response (SPA fallback).
# Note: framing is controlled by CSP `frame-ancestors` only — we intentionally
# do NOT set `X-Frame-Options: DENY` because it would also block the Lovable
# editor preview iframe (lovable.dev embedding lovableproject.com/lovable.app).
# `frame-ancestors` below allows only self + Lovable preview/editor origins.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://*.paddle.com https://cdn.paddle.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https://*.supabase.co https://*.lovable.app; media-src 'self' blob: https://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.paddle.com https://*.lovable.app; frame-src 'self' https://*.paddle.com; frame-ancestors 'self' https://*.lovable.app https://*.lovableproject.com https://lovable.dev https://*.lovable.dev; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests


